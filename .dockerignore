# Keep the build context small. Source is bind-mounted at runtime anyway.
.git
.gitignore
.github

# Host dependency dirs (installed inside the containers / volumes instead)
node_modules
vendor

# Build output (regenerated by the vite container)
public/build
public/hot

# Local env & caches
.env
.env.backup
.env.*.local
storage/logs/*
storage/framework/cache/*
storage/framework/sessions/*
storage/framework/views/*
bootstrap/cache/*.php

# OS / editor cruft
.DS_Store
Thumbs.db
.idea
.vscode

# The docker files themselves don't need to be in the image build context root copy
docker-compose*.yaml
