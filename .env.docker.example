# =============================================================================
# Environment for running the ERP with docker-compose (development).
# Copy to .env:   cp .env.docker.example .env
# The app container will also do this automatically on first boot if .env is
# missing, then generate APP_KEY for you.
# =============================================================================

APP_NAME="ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
# Must match the port published by the "web" service.
APP_URL=http://localhost:8000
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_LEVEL=debug

# --- Database (points at the "mysql" service) --------------------------------
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=designvision
DB_USERNAME=erp
DB_PASSWORD=secret
# Used by the mysql container only:
DB_ROOT_PASSWORD=root

# --- Cache / Session / Queue -------------------------------------------------
# Defaults match the app (file cache/session, database queue). The queue
# container processes the app's queued event listeners.
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_DRIVER=file
CACHE_STORE=file
QUEUE_CONNECTION=database

# To use Redis instead, set the three above to redis and uncomment:
# REDIS_CLIENT=phpredis
# REDIS_HOST=redis
# REDIS_PASSWORD=null
# REDIS_PORT=6379

# --- Mail (log driver writes to storage/logs in dev) -------------------------
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# --- Filesystem --------------------------------------------------------------
FILESYSTEM_DISK=public

# --- Vite (HMR served by the "vite" service on host port 5173) ---------------
VITE_APP_NAME="${APP_NAME}"
VITE_DEV_SERVER_HOST=0.0.0.0
VITE_HMR_HOST=localhost

# =============================================================================
# docker-compose-only knobs (read by docker-compose.yaml, not by Laravel)
# =============================================================================
# Match these to your host user to avoid file-permission issues on Linux:
UID=1000
GID=1000

APP_PORT=8000
VITE_PORT=5173
# Host port for MySQL. 3307 avoids clashing with a local XAMPP/MySQL on 3306.
DB_FORWARD_PORT=3307
REDIS_FORWARD_PORT=6379

# File-watch polling for Vite HMR. Needed when the project lives on the Windows
# filesystem (C:\...). Set to false when running from inside the WSL2 filesystem
# (~/...) for much lower CPU and faster HMR.
CHOKIDAR_USEPOLLING=true

# First-run automation handled by the app container's entrypoint:
AUTO_MIGRATE=false
AUTO_SEED=false
MARK_INSTALLED=false
